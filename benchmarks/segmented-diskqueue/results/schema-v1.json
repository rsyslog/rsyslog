{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rsyslog normalized performance comparison",
  "type": "object",
  "required": ["schema_version", "baseline_revision", "candidate_revision", "session", "comparisons"],
  "properties": {
    "schema_version": {"const": 1},
    "baseline_revision": {"type": "string"},
    "candidate_revision": {"type": "string"},
    "session": {"type": "string"},
    "host_exclusive": {"type": "boolean"},
    "cache_state": {"type": "string"},
    "comparisons": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "required": ["scenario", "mode", "payload_bytes", "batch_size", "segment_bytes", "metrics"]
          },
          {
            "type": "object",
            "required": ["candidate", "status"]
          }
        ]
      }
    }
  },
  "additionalProperties": true
}
